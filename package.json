{
  "name": "tempo",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "cln": "bash scripts/clean-node-modules.sh",
    "sync:lan-env": "bash scripts/sync-dev-lan-env.sh",
    "start": "bash scripts/dev-iterm.sh",
    "dev": "bash scripts/dev-iterm.sh",
    "dev:web": "pnpm --filter web dev",
    "dev:app": "pnpm --filter app start",
    "dev:service": "cd service && PATH=\"$HOME/.local/bin:$PATH\" uv run uvicorn app.main:app --reload --host 0.0.0.0 --port 8000"
  }
}